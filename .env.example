# Backend env vars — set these in Vercel project settings (or backend/.env.local for `vercel dev`)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=                    # required only for gemini.google.com

# Extension env — set in extension/config.js (copied from config.example.js)
# Points the extension at your deployed backend
ECHO_API_BASE_URL=https://your-vercel-deploy.vercel.app
