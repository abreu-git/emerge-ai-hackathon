{
  "manifest_version": 3,
  "name": "Echo — Sycophancy Detector for ChatGPT, Claude & Gemini",
  "version": "0.3.0",
  "description": "Catch when your LLM is telling you what you want to hear. Echo runs 3 adversarial variants on every answer and scores consistency 0–100 in real time.",
  "action": {
    "default_title": "Open Echo",
    "default_icon": {
      "16": "icons/echo-16.png",
      "32": "icons/echo-32.png",
      "48": "icons/echo-48.png",
      "128": "icons/echo-128.png"
    }
  },
  "icons": {
    "16": "icons/echo-16.png",
    "32": "icons/echo-32.png",
    "48": "icons/echo-48.png",
    "128": "icons/echo-128.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://claude.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://claude.com/*",
    "https://gemini.google.com/*",
    "http://localhost/*",
    "http://localhost:3939/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:3939/*",
    "https://echo-backend-production-7055.up.railway.app/*"
  ]
}
