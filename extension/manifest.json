{
  "manifest_version": 3,
  "name": "Echo — Personal Red Teaming for LLMs",
  "version": "0.2.0",
  "description": "See the same AI from every angle. Real-time consistency scoring for ChatGPT (and soon Claude, Gemini).",
  "action": {
    "default_title": "Open Echo",
    "default_icon": {
      "16": "icons/echo-16.png",
      "32": "icons/echo-32.png",
      "48": "icons/echo-48.png",
      "128": "icons/echo-128.png"
    }
  },
  "icons": {
    "16": "icons/echo-16.png",
    "32": "icons/echo-32.png",
    "48": "icons/echo-48.png",
    "128": "icons/echo-128.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ]
}
